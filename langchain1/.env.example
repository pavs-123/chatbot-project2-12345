# LangChain1 Production Configuration

# LLM Provider (choose one)
OPENAI_API_KEY=your-openai-key-here
ANTHROPIC_API_KEY=your-anthropic-key-here
GROQ_API_KEY=your-groq-key-here

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8002
DEBUG=false
LOG_LEVEL=INFO

# Security
API_KEY=your-secret-api-key-here
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Database (for persistent memory)
DATABASE_URL=sqlite:///./langchain1.db
# For PostgreSQL: postgresql://user:pass@localhost/langchain1

# Redis (for session storage - optional)
REDIS_URL=redis://localhost:6379/0

# Memory Settings
MAX_MEMORY_TOKENS=2000
SUMMARY_MAX_TOKENS=500
WINDOW_SIZE=10

# RAG Settings
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=3

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# Tool Settings
ENABLE_CALCULATOR=true
ENABLE_PYTHON_REPL=false  # Security risk - disable in production
ENABLE_RAG=true
ENABLE_WEATHER=true
ENABLE_EMAIL=false
ENABLE_DATABASE=false

# Monitoring
SENTRY_DSN=
ENABLE_METRICS=true
METRICS_PORT=9090
